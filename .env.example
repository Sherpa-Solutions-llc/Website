# FreeMe Configuration Credentials
# Rename this file to .env and fill in your values

# 1. Vision-Language Model Configuration
# Required for autonomous agents to visually locate opt-out forms
# Choose one of the following:
OPENAI_API_KEY="sk-proj-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# 2. Inbox Automator Configuration
# The dedicated email address that receives data broker confirmation links
FREEME_EMAIL_ADDRESS="your.burner.email@gmail.com"
# An App Password (not your main password) generated from your email provider
FREEME_EMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
FREEME_IMAP_SERVER="imap.gmail.com"
